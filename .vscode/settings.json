{
    "mcpServers": {
        "mui-mcp": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "-y",
                "@mui/mcp@latest"
            ]
        }
    },
    "chat.mcp.discovery.enabled": {
        "claude-desktop": true,
        "antigravity": true,
        "cursor-global": true,
        "cursor-workspace": true
    },
    "chat.mcp.access": "all"
}